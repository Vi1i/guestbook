# Required — change this to a random secret in production
GUESTBOOK_SECRET_KEY=change-me-in-production

# Public URL (used in emails and QR codes)
GUESTBOOK_BASE_URL=http://localhost:8000

# Debug mode
GUESTBOOK_DEBUG=false

# Database — SQLite (default) or PostgreSQL
# GUESTBOOK_DATABASE_URL=sqlite+aiosqlite:///./guestbook.db
# GUESTBOOK_DATABASE_URL=postgresql+asyncpg://user:pass@localhost/guestbook

# SMTP (only needed when mail_backend=smtp)
# GUESTBOOK_SMTP_HOST=localhost
# GUESTBOOK_SMTP_PORT=587
# GUESTBOOK_SMTP_USER=
# GUESTBOOK_SMTP_PASSWORD=
# GUESTBOOK_SMTP_FROM=guestbook@localhost

# Mail backend: "console" prints magic links to stdout, "smtp" sends real email
GUESTBOOK_MAIL_BACKEND=console

# Session cookie max age in seconds (default: 7 days)
# GUESTBOOK_SESSION_MAX_AGE=604800

# Magic link token expiry in hours
# GUESTBOOK_TOKEN_EXPIRY_HOURS=24

# Rate limit for auth endpoints
# GUESTBOOK_RATE_LIMIT_AUTH=3/hour
