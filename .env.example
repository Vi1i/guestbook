# Required — change this to a random secret in production
GUESTBOOK_SECRET_KEY=change-me-in-production

# Public URL (used in emails and QR codes)
GUESTBOOK_BASE_URL=http://localhost:8000

# Debug mode (verbose logging, non-secure cookies)
GUESTBOOK_DEBUG=false

# Development mode (enables /dev/login page, impersonation, quick user creation)
# GUESTBOOK_DEVELOPMENT=false

# Server bind
# GUESTBOOK_HOST=0.0.0.0
# GUESTBOOK_PORT=8000

# Database — SQLite (default) or PostgreSQL
# GUESTBOOK_DATABASE_URL=sqlite+aiosqlite:///./guestbook.db
# GUESTBOOK_DATABASE_URL=postgresql+asyncpg://guestbook:changeme@postgres/guestbook

# Mail backend: "console" prints magic links to stdout, "smtp" sends real email
GUESTBOOK_MAIL_BACKEND=console

# SMTP — example for Resend (port 465 = SSL, port 587 = STARTTLS)
# GUESTBOOK_SMTP_HOST=smtp.resend.com
# GUESTBOOK_SMTP_PORT=465
# GUESTBOOK_SMTP_USER=resend
# GUESTBOOK_SMTP_PASSWORD=re_YOUR_API_KEY
# GUESTBOOK_SMTP_FROM=guestbook@yourdomain.com

# Session cookie max age in seconds (default: 7 days)
# GUESTBOOK_SESSION_MAX_AGE=604800

# Magic link token expiry in hours
# GUESTBOOK_TOKEN_EXPIRY_HOURS=24

# Rate limit for auth endpoints
# GUESTBOOK_RATE_LIMIT_AUTH=3/hour

# PostgreSQL password (used by docker-compose postgres profile)
# POSTGRES_PASSWORD=changeme

# SWAG network name (docker network that SWAG uses)
# SWAG_NETWORK=swag
